<% layout('/layouts/boilerplate') %>
<body>
    <div class="row">
        <div class="col-8 mt-2 offset-3">
            <h3><%= listing.title %></h3>
        </div>
    <div class="col-6 offset-3">
        <div class="card listing-card" >
    <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing image">
  <div class="card-body">
   
        <p class="card-text">Owned by :<%= listing.owner.username %></p>   
        <p class="card-text"><%= listing.description %></p>
        <p class="card-text"><%= listing.price.toLocaleString('en-IN') %></p>
        <p class="card-text"><%= listing.location %></p>
        <p class="card-text"><%= listing.country %></p>
  </div>
</div>
    </div>
    <% if(currUser && currUser._id.equals(listing.owner._id)){ %>
    <div class="btns">
        <a href="/listing/<%= listing._id %>/edit" class="col-1 btn btn-dark offset-3 add-btn">Edit</a>
    <br><br>
    <form method="post" action="/listing/<%= listing._id %>?_method=DELETE" >
        <button class="btn btn-dark offset-3">Delete</button>
    </form>
    </div>
    <% } %>
    <hr>   
    <div class="col-8 mt-2 offset-3 mb-3" >
        <% if(currUser){ %>
        <h4>Leave A Review</h4>
        <form method="post" action="/listing/<%=listing._id%>/reviews" novalidate class="needs-validation">
            <div class="md-3 mt-3">
                <label for="rating" class="form-lable">Rating</label>
                <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
            </div>
            <div class="md-3 mt-3">
                <label for="comment" class="form-lable">Comment</label>
                <textarea id="comment" name="review[comment]" rows="3" cols="50" class="form-control" required></textarea>
                <div class="invalid-feedback">Please Enter Review.</div>
            </div>
            <button class="btn btn-outline-dark md-3 mt-3">Submit</button>
        </form> 
        <hr>
        <% } %>
    </div>
    
            <div class="col-8 mt-2 offset-3 mb-3">
                <p><b>All Reviews</b></p>
                <div class="row">
                <% for(review of listing.reviews){ %>
                    <div class="card col-5 ms-3 mb-3">
                        <div class="card-body">
                        <h5 class="card-title"><%= review.author.username %> </h5>
                        <p class="card-text"><%= review.comment %></p>
                        <p class="card-text"><%= review.rating %> stars</p>
                        </div>
                        <div>
                            <form class="mb-3" method="post" action="/listing/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                <button class="btn btn-sm btn-dark">Delete</button>
                            </form>
                        </div>
                    </div>
                <% } %>
                </div>
            </div>
    </div>
</body>

