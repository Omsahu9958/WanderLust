<% layout('/layouts/boilerplate') %>
 <div class="row">
        <h1 class="col-6 offset-3">LogIn On WanderLust</h1>
        <div class="col-6 offset-3">
                <form method="post" action="/login" novalidate class="needs-validation">
                    <div class="mb-3">
                        <label for="username" class="form-lable">Username</label>
                        <input name="username"
                         type="text" 
                         class="form-control"
                         id="username" 
                         required>
                    </div>
                    <div class="mb-3">
                        <label for="pasword" class="form-lable">Password</label>
                        <input name="password"
                         type="password" 
                         class="form-control"
                         id="password" 
                         required>
                    </div>
                    <button class="btn btn-success">LogIn</button>
                </form>
        </div>
 </div>